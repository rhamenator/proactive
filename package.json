{
  "name": "proactive-field-canvassing-system",
  "private": true,
  "version": "0.1.0",
  "license": "MIT",
  "workspaces": [
    "backend",
    "admin-dashboard",
    "mobile-app"
  ],
  "scripts": {
    "postinstall": "npm run prisma:generate",
    "build": "npm run build --workspace @proactive/backend && npm run build --workspace @proactive/admin-dashboard && npm run typecheck --workspace mobile-app",
    "test": "npm test --workspace @proactive/backend -- --runInBand && npm test --workspace @proactive/admin-dashboard && npm test --workspace mobile-app",
    "test:coverage": "npm test --workspace @proactive/backend -- --runInBand --coverage --coverageReporters=text-summary && npm run test:coverage --workspace @proactive/admin-dashboard && npm run test:coverage --workspace mobile-app",
    "typecheck": "npm run typecheck --workspace @proactive/admin-dashboard && npm run typecheck --workspace mobile-app",
    "verify": "npm run prisma:generate && npm run build && npm test",
    "setup:local": "bash scripts/install-local.sh",
    "setup:mobile": "bash scripts/install-mobile.sh",
    "prisma:generate": "npm run prisma:generate --workspace @proactive/backend",
    "dev:backend": "npm run start:dev --workspace @proactive/backend",
    "dev:admin": "npm run dev --workspace @proactive/admin-dashboard",
    "dev:mobile": "npm run start --workspace mobile-app",
    "test:ui": "npm run test:e2e --workspace @proactive/admin-dashboard",
    "test:ui:mocked": "npm run test:e2e:mocked --workspace @proactive/admin-dashboard",
    "test:ui:seeded": "npm run test:e2e:seeded --workspace @proactive/admin-dashboard",
    "seed:e2e": "npm run prisma:seed:e2e --workspace @proactive/backend",
    "test:mobile:e2e:ios": "npm run test:e2e:mobile:ios --workspace mobile-app",
    "build:mobile:e2e:ios": "npm run build:e2e:mobile:ios --workspace mobile-app"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "overrides": {
    "path-to-regexp": "8.4.2",
    "effect": "3.21.2",
    "expo": "55.0.17",
    "@expo/cli": "55.0.26",
    "@expo/config": "55.0.15",
    "@expo/config-plugins": "55.0.8",
    "@expo/dom-webview": "55.0.5",
    "@expo/local-build-cache-provider": "55.0.11",
    "@expo/log-box": "55.0.11",
    "@expo/metro": "55.1.0",
    "@expo/metro-config": "55.0.17",
    "@expo/prebuild-config": "55.0.16",
    "@expo/router-server": "55.0.15",
    "babel-preset-expo": "55.0.18",
    "expo-asset": "55.0.16",
    "expo-constants": "55.0.15",
    "expo-file-system": "55.0.17",
    "expo-font": "55.0.6",
    "expo-keep-awake": "55.0.6",
    "expo-modules-autolinking": "55.0.18",
    "expo-modules-core": "55.0.23",
    "xcode": {
      "uuid": "14.0.0"
    }
  },
  "dependencies": {
    "@nestjs/common": "11.1.19",
    "effect": "3.21.2",
    "path-to-regexp": "8.4.2"
  }
}
