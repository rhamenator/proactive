# Copy this file to .env and fill in values before running `docker compose up`.
#
# Required — no defaults, the app will refuse to start without these.
POSTGRES_PASSWORD=change_me_in_production
JWT_SECRET=change_me_in_production

# Optional — sensible defaults are shown.
POSTGRES_USER=proactive
POSTGRES_DB=proactive
BACKEND_PORT=3001
DASHBOARD_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:3001
