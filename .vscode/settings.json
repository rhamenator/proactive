{
    "jest.rootPath": "backend",
    "jest.jestCommandLine": "npx jest --config ./jest.config.cjs --runInBand",
    "html-validate.validate": [
        "html",
        "markdown",
        "vue",
        "vue-html",
        "jsx",
        "tsx"
    ],
    "mssql.intelliSense.enableIntelliSense": false,
    "mssql.intelliSense.enableErrorChecking": false,
    "mssql.intelliSense.enableSuggestions": false,
    "mssql.intelliSense.enableQuickInfo": false,
    "files.associations": {
        "**/backend/prisma/migrations/**/*.sql": "plaintext",
        "**/prisma/migrations/**/*.sql": "plaintext",
        "*.sql": "plaintext"
    },
    "files.exclude": {
        "**/.git": true,
        "**/.svn": true,
        "**/.hg": true,
        "**/.DS_Store": true,
        "**/Thumbs.db": true
    },
    "problems.exclude": {
        "**/backend/prisma/migrations/**/*.sql": true,
        "**/prisma/migrations/**/*.sql": true
    },
    "explorerExclude.backup": {},
    "cSpell.words": [
        "geofence"
    ]
}
