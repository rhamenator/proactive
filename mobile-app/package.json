{
  "name": "mobile-app",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "start:clear": "expo start --clear",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e:mobile:ios": "detox test --configuration ios.sim.debug",
    "build:e2e:mobile:ios": "detox build --configuration ios.sim.debug",
    "eas:build:ios:preview": "npx eas build --platform ios --profile preview",
    "eas:build:android:preview": "npx eas build --platform android --profile preview",
    "eas:build:ios:production": "npx eas build --platform ios --profile production",
    "eas:build:android:production": "npx eas build --platform android --profile production",
    "eas:submit:ios": "npx eas submit --platform ios --profile production",
    "eas:submit:android": "npx eas submit --platform android --profile production",
    "eas:update:preview": "npx eas update --branch preview --environment preview",
    "eas:update:production": "npx eas update --branch production --environment production"
  },
  "dependencies": {
    "@react-native-community/netinfo": "^12.0.1",
    "@react-navigation/native": "^7.2.1",
    "@react-navigation/native-stack": "^7.14.9",
    "expo": "~55.0.9",
    "expo-location": "~55.1.4",
    "expo-sqlite": "~16.0.8",
    "expo-status-bar": "~55.0.4",
    "react": "19.2.0",
    "react-native": "0.83.4",
    "react-native-safe-area-context": "^5.7.0",
    "react-native-screens": "^4.24.0"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "@vitest/coverage-v8": "^3.2.4",
    "detox": "^20.29.3",
    "jest": "^29.7.0",
    "typescript": "~5.9.2",
    "vitest": "^3.2.4"
  },
  "private": true
}
