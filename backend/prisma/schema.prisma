model AddressRequest {
  id                String               @id @default(uuid()) @db.Uuid
  turfId            String               @map("turf_id") @db.Uuid
  organizationId    String?              @map("organization_id") @db.Uuid
  campaignId        String?              @map("campaign_id") @db.Uuid
  teamId            String?              @map("team_id") @db.Uuid
  regionCode        String?              @map("region_code")
  requestedByUserId String               @map("requested_by_user_id") @db.Uuid
  reviewedByUserId  String?              @map("reviewed_by_user_id") @db.Uuid
  approvedAddressId String?              @map("approved_address_id") @db.Uuid
  status            AddressRequestStatus @default(pending)
  addressLine1      String               @map("address_line1")
  city              String
  state             String
  zip               String?
  latitude          Decimal?             @db.Decimal(9, 6)
  longitude         Decimal?             @db.Decimal(9, 6)
  notes             String?
  submittedAt       DateTime             @default(now()) @map("submitted_at")
  reviewedAt        DateTime?            @map("reviewed_at")
  reviewReason      String?              @map("review_reason")
  archivedAt        DateTime?            @map("archived_at")
  purgeAt           DateTime?            @map("purge_at")
  turf              Turf                 @relation(fields: [turfId], references: [id], onDelete: Cascade)
  organization      Organization?        @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  campaign          Campaign?            @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  team              Team?                @relation(fields: [teamId], references: [id], onDelete: SetNull)
  requestedByUser   User                 @relation("AddressRequestSubmitter", fields: [requestedByUserId], references: [id], onDelete: Cascade)
  reviewedByUser    User?                @relation("AddressRequestReviewer", fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  approvedAddress   Address?             @relation("AddressRequestApprovedAddress", fields: [approvedAddressId], references: [id], onDelete: SetNull)

  @@index([turfId])
  @@index([organizationId])
  @@index([campaignId])
  @@index([teamId])
  @@index([regionCode])
  @@index([requestedByUserId])
  @@index([reviewedByUserId])
  @@index([status])
  @@map("address_requests")
}

