model OperationalPolicy {
  id                       String        @id @default(uuid()) @db.Uuid
  scopeKey                 String        @unique @map("scope_key")
  organizationId           String        @map("organization_id") @db.Uuid
  campaignId               String?       @map("campaign_id") @db.Uuid
  defaultImportProfileCode String        @default("van_standard") @map("default_import_profile_code")
  defaultImportMode        String        @default("create_only") @map("default_import_mode")
  defaultDuplicateStrategy String        @default("skip") @map("default_duplicate_strategy")
  defaultVanExportProfileCode String     @default("van_compatible") @map("default_van_export_profile_code")
  defaultInternalExportProfileCode String @default("internal_master") @map("default_internal_export_profile_code")
  sensitiveMfaWindowMinutes Int          @default(5) @map("sensitive_mfa_window_minutes")
  canvasserCorrectionWindowMinutes Int   @default(10) @map("canvasser_correction_window_minutes")
  maxAttemptsPerHousehold Int            @default(3) @map("max_attempts_per_household")
  minMinutesBetweenAttempts Int          @default(5) @map("min_minutes_between_attempts")
  geofenceRadiusFeet       Int           @default(75) @map("geofence_radius_feet")
  gpsLowAccuracyMeters     Int           @default(30) @map("gps_low_accuracy_meters")
  refreshTokenTtlDays      Int           @default(14) @map("refresh_token_ttl_days")
  activationTokenTtlHours  Int           @default(48) @map("activation_token_ttl_hours")
  passwordResetTtlMinutes  Int           @default(30) @map("password_reset_ttl_minutes")
  loginLockoutThreshold    Int           @default(5) @map("login_lockout_threshold")
  loginLockoutMinutes      Int           @default(15) @map("login_lockout_minutes")
  mfaChallengeTtlMinutes   Int           @default(10) @map("mfa_challenge_ttl_minutes")
  mfaBackupCodeCount       Int           @default(10) @map("mfa_backup_code_count")
  retentionArchiveDays     Int?          @map("retention_archive_days")
  retentionPurgeDays       Int?          @map("retention_purge_days")
  requireArchiveReason     Boolean       @default(false) @map("require_archive_reason")
  allowOrgOutcomeFallback  Boolean       @default(true) @map("allow_org_outcome_fallback")
  supervisorScopeMode      SupervisorScopeMode @default(campaign) @map("supervisor_scope_mode")
  createdAt                DateTime      @default(now()) @map("created_at")
  updatedAt                DateTime      @updatedAt @map("updated_at")
  organization             Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  campaign                 Campaign?     @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([campaignId])
  @@map("operational_policies")
}

model ImpersonationSession {
