generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  supervisor
  canvasser
}

enum AssignmentStatus {
  assigned
  active
  completed
  removed
}

enum VisitResult {
  knocked
  lit_drop
  not_home
  refused
  talked_to_voter
  other
}

enum SyncStatus {
  pending
  syncing
  synced
  failed
  conflict
}

enum GpsStatus {
  verified
  flagged
  missing
  low_accuracy
}

enum VisitSource {
  mobile_app
  web_app
  csv_import
  admin_entry
}

enum TurfStatus {
  unassigned
  assigned
  in_progress
  paused
  completed
  reopened
  archived
}

enum SessionStatus {
  active
  paused
  ended
  force_closed
}

enum MfaChallengePurpose {
  setup
  verify
}

enum AddressRequestStatus {
  pending
  approved
  rejected
}

enum CsvProfileDirection {
  import
  export
}

enum SupervisorScopeMode {
  campaign
  team
  region
}

model User {
  id                            String                 @id @default(uuid()) @db.Uuid
  firstName                     String                 @map("first_name")
  lastName                      String                 @map("last_name")
  email                         String                 @unique
  passwordHash                  String                 @map("password_hash")
  role                          UserRole
  organizationId                String?                @map("organization_id") @db.Uuid
  campaignId                    String?                @map("campaign_id") @db.Uuid
  teamId                        String?                @map("team_id") @db.Uuid
  regionCode                    String?                @map("region_code")
  isActive                      Boolean                @default(true) @map("is_active")
  status                        String                 @default("active")
  mfaEnabled                    Boolean                @default(false) @map("mfa_enabled")
  mfaSecret                     String?                @map("mfa_secret")
  mfaTempSecret                 String?                @map("mfa_temp_secret")
  failedLoginAttempts           Int                    @default(0) @map("failed_login_attempts")
  lockedUntil                   DateTime?              @map("locked_until")
  invitedAt                     DateTime?              @map("invited_at")
  activatedAt                   DateTime?              @map("activated_at")
  lastLoginAt                   DateTime?              @map("last_login_at")
  deletedAt                     DateTime?              @map("deleted_at")
  deleteReason                  String?                @map("delete_reason")
  archivedAt                    DateTime?              @map("archived_at")
  purgeAt                       DateTime?              @map("purge_at")
  createdAt                     DateTime               @default(now()) @map("created_at")
  organization                  Organization?          @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  campaign                      Campaign?              @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  team                          Team?                  @relation(fields: [teamId], references: [id], onDelete: SetNull)
  createdTurfs                  Turf[]                 @relation("TurfsCreated")
  assignments                   TurfAssignment[]
  sessions                      TurfSession[]
  visits                        VisitLog[]
  auditLogs                     AuditLog[]             @relation("AuditActor")
  exportBatches                 ExportBatch[]          @relation("ExportBatchesInitiated")
  importBatches                 ImportBatch[]          @relation("ImportBatchesInitiated")
  mfaChallenges                 MfaChallengeToken[]
  mfaBackupCodes                MfaBackupCode[]
  impersonationSessionsStarted  ImpersonationSession[] @relation("ImpersonationActor")
  impersonationSessionsTargeted ImpersonationSession[] @relation("ImpersonationTarget")
  submittedAddressRequests      AddressRequest[]       @relation("AddressRequestSubmitter")
  reviewedAddressRequests       AddressRequest[]       @relation("AddressRequestReviewer")
  visitCorrections              VisitCorrection[]      @relation("VisitCorrectionActor")
  resolvedImportBatchRows       ImportBatchRow[]
  refreshTokens                 AuthRefreshToken[]
  activationTokens              ActivationToken[]
  resetTokens                   PasswordResetToken[]

  @@index([organizationId])
  @@index([campaignId])
  @@index([teamId])
  @@index([regionCode])
  @@map("users")
}

model Organization {
  id                    String                 @id @default(uuid()) @db.Uuid
  code                  String                 @unique
  name                  String
  createdAt             DateTime               @default(now()) @map("created_at")
  users                 User[]
  campaigns             Campaign[]
  households            Household[]
  teams                 Team[]
  turfs                 Turf[]
  addresses             Address[]
  assignments           TurfAssignment[]
  sessions              TurfSession[]
  visits                VisitLog[]
  auditLogs             AuditLog[]
  outcomes              OutcomeDefinition[]
  importBatches         ImportBatch[]
  addressRequests       AddressRequest[]
  impersonationSessions ImpersonationSession[]
  visitCorrections      VisitCorrection[]
  exportBatches         ExportBatch[]
  operationalPolicies   OperationalPolicy[]
  csvProfiles           CsvProfile[]

  @@map("organizations")
}

model SystemConfiguration {
  id                          String   @id @default("global")
  authRateLimitWindowMinutes  Int      @default(15) @map("auth_rate_limit_window_minutes")
  authRateLimitMaxAttempts    Int      @default(10) @map("auth_rate_limit_max_attempts")
  retentionJobEnabled         Boolean  @default(false) @map("retention_job_enabled")
  retentionJobIntervalMinutes Int      @default(60) @map("retention_job_interval_minutes")
  createdAt                   DateTime @default(now()) @map("created_at")
  updatedAt                   DateTime @updatedAt @map("updated_at")

  @@map("system_configuration")
}

model Household {
  id              String           @id @default(uuid()) @db.Uuid
  organizationId  String?          @map("organization_id") @db.Uuid
  addressLine1    String           @map("address_line1")
  city            String
  state           String
  zip             String?
  latitude        Decimal?         @db.Decimal(9, 6)
  longitude       Decimal?         @db.Decimal(9, 6)
  vanHouseholdId  String?          @map("van_household_id")
  vanPersonId     String?          @map("van_person_id")
  source          String           @default("csv_import")
  approvalStatus  String           @default("approved") @map("approval_status")
  legacyAddressId String?          @unique @map("legacy_address_id") @db.Uuid
  deletedAt       DateTime?        @map("deleted_at")
  deleteReason    String?          @map("delete_reason")
  archivedAt      DateTime?        @map("archived_at")
  purgeAt         DateTime?        @map("purge_at")
  createdAt       DateTime         @default(now()) @map("created_at")
  organization    Organization?    @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  addresses       Address[]
  importRows      ImportBatchRow[]

  @@index([organizationId])
  @@index([organizationId, addressLine1, city, state, zip])
  @@index([organizationId, vanHouseholdId])
  @@index([organizationId, vanPersonId])
  @@map("households")
}

model Team {
  id             String        @id @default(uuid()) @db.Uuid
  organizationId String        @map("organization_id") @db.Uuid
  campaignId     String?       @map("campaign_id") @db.Uuid
  code           String
  name           String
  regionCode     String?       @map("region_code")
  isActive       Boolean       @default(true) @map("is_active")
  createdAt      DateTime      @default(now()) @map("created_at")
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  campaign       Campaign?     @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  users          User[]
  turfs          Turf[]
  addresses      Address[]
  assignments    TurfAssignment[]
  sessions       TurfSession[]
  visits         VisitLog[]
  addressRequests AddressRequest[]
  importBatches  ImportBatch[]
  exportBatches  ExportBatch[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@index([campaignId])
  @@index([regionCode])
  @@map("teams")
}

model Campaign {
  id                    String                 @id @default(uuid()) @db.Uuid
  organizationId        String                 @map("organization_id") @db.Uuid
  code                  String
  name                  String
  isActive              Boolean                @default(true) @map("is_active")
  createdAt             DateTime               @default(now()) @map("created_at")
  organization          Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  users                 User[]
  teams                 Team[]
  turfs                 Turf[]
  addresses             Address[]
  assignments           TurfAssignment[]
  sessions              TurfSession[]
  visits                VisitLog[]
  outcomes              OutcomeDefinition[]
  addressRequests       AddressRequest[]
  impersonationSessions ImpersonationSession[]
  visitCorrections      VisitCorrection[]
  exportBatches         ExportBatch[]
  importBatches         ImportBatch[]
  operationalPolicies   OperationalPolicy[]
  csvProfiles           CsvProfile[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@map("campaigns")
}

model OutcomeDefinition {
  id                 String        @id @default(uuid()) @db.Uuid
  organizationId     String?       @map("organization_id") @db.Uuid
  campaignId         String?       @map("campaign_id") @db.Uuid
  code               String
  label              String
  requiresNote       Boolean       @default(false) @map("requires_note")
  isFinalDisposition Boolean       @default(true) @map("is_final_disposition")
  displayOrder       Int           @default(0) @map("display_order")
  isActive           Boolean       @default(true) @map("is_active")
  createdAt          DateTime      @default(now()) @map("created_at")
  organization       Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  campaign           Campaign?     @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  visits             VisitLog[]

  @@index([organizationId])
  @@index([campaignId])
  @@index([organizationId, campaignId, code])
  @@index([isActive, displayOrder])
  @@map("outcome_definitions")
}

model Turf {
  id              String           @id @default(uuid()) @db.Uuid
  name            String
  description     String?
  organizationId  String?          @map("organization_id") @db.Uuid
  campaignId      String?          @map("campaign_id") @db.Uuid
  teamId          String?          @map("team_id") @db.Uuid
  regionCode      String?          @map("region_code")
  status          TurfStatus       @default(unassigned)
  isShared        Boolean          @default(false) @map("is_shared")
  createdById     String?          @map("created_by") @db.Uuid
  completedAt     DateTime?        @map("completed_at")
  completedById   String?          @map("completed_by") @db.Uuid
  reopenedAt      DateTime?        @map("reopened_at")
  reopenedById    String?          @map("reopened_by") @db.Uuid
  reopenedReason  String?          @map("reopened_reason")
  deletedAt       DateTime?        @map("deleted_at")
  deleteReason    String?          @map("delete_reason")
  archivedAt      DateTime?        @map("archived_at")
  purgeAt         DateTime?        @map("purge_at")
  createdAt       DateTime         @default(now()) @map("created_at")
  organization    Organization?    @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  campaign        Campaign?        @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  team            Team?            @relation(fields: [teamId], references: [id], onDelete: SetNull)
  createdBy       User?            @relation("TurfsCreated", fields: [createdById], references: [id])
  addresses       Address[]
  assignments     TurfAssignment[]
  sessions        TurfSession[]
  visits          VisitLog[]
  exportBatches   ExportBatch[]
  addressRequests AddressRequest[]

  @@index([organizationId])
  @@index([campaignId])
  @@index([teamId])
  @@index([regionCode])
  @@map("turfs")
}

model Address {
  id              String                @id @default(uuid()) @db.Uuid
  turfId          String                @map("turf_id") @db.Uuid
  householdId     String                @map("household_id") @db.Uuid
  organizationId  String?               @map("organization_id") @db.Uuid
  campaignId      String?               @map("campaign_id") @db.Uuid
  teamId          String?               @map("team_id") @db.Uuid
  regionCode      String?               @map("region_code")
  addressLine1    String                @map("address_line1")
  city            String
  state           String
  zip             String?
  latitude        Decimal?              @db.Decimal(9, 6)
  longitude       Decimal?              @db.Decimal(9, 6)
  vanId           String?               @map("van_id")
  addedInField    Boolean               @default(false) @map("added_in_field")
  deletedAt       DateTime?             @map("deleted_at")
  deleteReason    String?               @map("delete_reason")
  archivedAt      DateTime?             @map("archived_at")
  purgeAt         DateTime?             @map("purge_at")
  createdAt       DateTime              @default(now()) @map("created_at")
  organization    Organization?         @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  campaign        Campaign?             @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  team            Team?                 @relation(fields: [teamId], references: [id], onDelete: SetNull)
  turf            Turf                  @relation(fields: [turfId], references: [id], onDelete: Cascade)
  household       Household             @relation(fields: [householdId], references: [id], onDelete: Cascade)
  visitLogs       VisitLog[]
  geofenceResults VisitGeofenceResult[]
  requestedFrom       AddressRequest[]  @relation("AddressRequestApprovedAddress")
  resolvedImportRows  ImportBatchRow[]  @relation("ResolvedImportBatchRowAddress")
  candidateImportRows ImportBatchRow[]  @relation("CandidateImportBatchRowAddress")

  @@index([turfId])
  @@index([householdId])
  @@index([organizationId])
  @@index([campaignId])
  @@index([teamId])
  @@index([regionCode])
  @@index([turfId, householdId])
  @@map("addresses")
}

model TurfAssignment {
  id                 String           @id @default(uuid()) @db.Uuid
  turfId             String           @map("turf_id") @db.Uuid
  canvasserId        String           @map("canvasser_id") @db.Uuid
  organizationId     String?          @map("organization_id") @db.Uuid
  campaignId         String?          @map("campaign_id") @db.Uuid
  teamId             String?          @map("team_id") @db.Uuid
  regionCode         String?          @map("region_code")
  assignedByUserId   String?          @map("assigned_by_user_id") @db.Uuid
  assignedAt         DateTime         @default(now()) @map("assigned_at")
  unassignedAt       DateTime?        @map("unassigned_at")
  reassignmentReason String?          @map("reassignment_reason")
  status             AssignmentStatus @default(assigned)
  organization       Organization?    @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  campaign           Campaign?        @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  team               Team?            @relation(fields: [teamId], references: [id], onDelete: SetNull)
  turf               Turf             @relation(fields: [turfId], references: [id], onDelete: Cascade)
  canvasser          User             @relation(fields: [canvasserId], references: [id], onDelete: Cascade)

  @@index([turfId])
  @@index([canvasserId])
  @@index([organizationId])
  @@index([campaignId])
  @@index([teamId])
  @@index([regionCode])
  @@map("turf_assignments")
}

model TurfSession {
  id             String        @id @default(uuid()) @db.Uuid
  turfId         String        @map("turf_id") @db.Uuid
  canvasserId    String        @map("canvasser_id") @db.Uuid
  organizationId String?       @map("organization_id") @db.Uuid
  campaignId     String?       @map("campaign_id") @db.Uuid
  teamId         String?       @map("team_id") @db.Uuid
  regionCode     String?       @map("region_code")
  startTime      DateTime      @map("start_time")
  endTime        DateTime?     @map("end_time")
  status         SessionStatus @default(active)
  lastActivityAt DateTime?     @map("last_activity_at")
  pauseReason    String?       @map("pause_reason")
  endReason      String?       @map("end_reason")
  startLat       Decimal?      @map("start_lat") @db.Decimal(9, 6)
  startLng       Decimal?      @map("start_lng") @db.Decimal(9, 6)
  endLat         Decimal?      @map("end_lat") @db.Decimal(9, 6)
  endLng         Decimal?      @map("end_lng") @db.Decimal(9, 6)
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  campaign       Campaign?     @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  team           Team?         @relation(fields: [teamId], references: [id], onDelete: SetNull)
  turf           Turf          @relation(fields: [turfId], references: [id], onDelete: Cascade)
  canvasser      User          @relation(fields: [canvasserId], references: [id], onDelete: Cascade)
  visits         VisitLog[]

  @@index([turfId])
  @@index([canvasserId])
  @@index([organizationId])
  @@index([campaignId])
  @@index([teamId])
  @@index([regionCode])
  @@index([status])
  @@map("turf_sessions")
}

model VisitLog {
  id                     String               @id @default(uuid()) @db.Uuid
  turfId                 String               @map("turf_id") @db.Uuid
  addressId              String               @map("address_id") @db.Uuid
  sessionId              String?              @map("session_id") @db.Uuid
  canvasserId            String               @map("canvasser_id") @db.Uuid
  organizationId         String?              @map("organization_id") @db.Uuid
  campaignId             String?              @map("campaign_id") @db.Uuid
  teamId                 String?              @map("team_id") @db.Uuid
  regionCode             String?              @map("region_code")
  outcomeDefinitionId    String?              @map("outcome_definition_id") @db.Uuid
  visitTime              DateTime             @default(now()) @map("visit_time")
  clientCreatedAt        DateTime?            @map("client_created_at")
  serverReceivedAt       DateTime             @default(now()) @map("server_received_at")
  localRecordUuid        String?              @unique @map("local_record_uuid")
  idempotencyKey         String?              @unique @map("idempotency_key")
  syncStatus             SyncStatus           @default(synced) @map("sync_status")
  syncConflictFlag       Boolean              @default(false) @map("sync_conflict_flag")
  syncConflictReason     String?              @map("sync_conflict_reason")
  source                 VisitSource          @default(mobile_app)
  latitude               Decimal?             @db.Decimal(9, 6)
  longitude              Decimal?             @db.Decimal(9, 6)
  accuracyMeters         Decimal?             @map("accuracy_meters") @db.Decimal(8, 2)
  gpsStatus              GpsStatus            @default(missing) @map("gps_status")
  result                 VisitResult
  outcomeCode            String               @default("knocked") @map("outcome_code")
  outcomeLabel           String               @default("Knocked") @map("outcome_label")
  contactMade            Boolean              @default(false) @map("contact_made")
  notes                  String?
  vanExported            Boolean              @default(false) @map("van_exported")
  geofenceValidated      Boolean              @default(true) @map("geofence_validated")
  geofenceDistanceMeters Int?                 @map("geofence_distance_meters")
  deletedAt              DateTime?            @map("deleted_at")
  deleteReason           String?              @map("delete_reason")
  archivedAt             DateTime?            @map("archived_at")
  purgeAt                DateTime?            @map("purge_at")
  organization           Organization?        @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  campaign               Campaign?            @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  team                   Team?                @relation(fields: [teamId], references: [id], onDelete: SetNull)
  outcomeDefinition      OutcomeDefinition?   @relation(fields: [outcomeDefinitionId], references: [id], onDelete: SetNull)
  turf                   Turf                 @relation(fields: [turfId], references: [id], onDelete: Cascade)
  address                Address              @relation(fields: [addressId], references: [id], onDelete: Cascade)
  session                TurfSession?         @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  canvasser              User                 @relation(fields: [canvasserId], references: [id], onDelete: Cascade)
  geofenceResult         VisitGeofenceResult?
  corrections            VisitCorrection[]
  exportBatchVisits      ExportBatchVisit[]

  @@index([turfId])
  @@index([addressId])
  @@index([canvasserId])
  @@index([sessionId])
  @@index([organizationId])
  @@index([campaignId])
  @@index([teamId])
  @@index([regionCode])
  @@index([outcomeDefinitionId])
  @@index([syncStatus])
  @@map("visit_logs")
}

model VisitGeofenceResult {
  id                     String    @id @default(uuid()) @db.Uuid
  visitLogId             String    @unique @map("visit_log_id") @db.Uuid
  addressId              String    @map("address_id") @db.Uuid
  targetLatitude         Decimal?  @map("target_latitude") @db.Decimal(9, 6)
  targetLongitude        Decimal?  @map("target_longitude") @db.Decimal(9, 6)
  capturedLatitude       Decimal?  @map("captured_latitude") @db.Decimal(9, 6)
  capturedLongitude      Decimal?  @map("captured_longitude") @db.Decimal(9, 6)
  accuracyMeters         Decimal?  @map("accuracy_meters") @db.Decimal(8, 2)
  distanceFromTargetFeet Decimal?  @map("distance_from_target_feet") @db.Decimal(10, 2)
  validationRadiusFeet   Int       @map("validation_radius_feet")
  gpsStatus              GpsStatus @map("gps_status")
  failureReason          String?   @map("failure_reason")
  capturedAt             DateTime? @map("captured_at")
  overrideFlag           Boolean   @default(false) @map("override_flag")
  overrideReason         String?   @map("override_reason")
  overrideByUserId       String?   @map("override_by_user_id") @db.Uuid
  overrideAt             DateTime? @map("override_at")
  createdAt              DateTime  @default(now()) @map("created_at")
  visitLog               VisitLog  @relation(fields: [visitLogId], references: [id], onDelete: Cascade)
  address                Address   @relation(fields: [addressId], references: [id], onDelete: Cascade)

  @@index([addressId])
  @@index([gpsStatus])
  @@map("visit_geofence_results")
}

model SyncEvent {
  id              String     @id @default(uuid()) @db.Uuid
  entityType      String     @map("entity_type")
  entityId        String     @map("entity_id")
  localRecordUuid String?    @map("local_record_uuid")
  idempotencyKey  String?    @map("idempotency_key")
  eventType       String     @map("event_type")
  syncStatus      SyncStatus @map("sync_status")
  attemptCount    Int        @default(1) @map("attempt_count")
  errorCode       String?    @map("error_code")
  errorMessage    String?    @map("error_message")
  queuedAt        DateTime   @default(now()) @map("queued_at")
  attemptedAt     DateTime?  @map("attempted_at")
  completedAt     DateTime?  @map("completed_at")

  @@index([entityType, entityId])
  @@index([localRecordUuid])
  @@index([syncStatus])
  @@map("sync_events")
}

model AuditLog {
  id             String        @id @default(uuid()) @db.Uuid
  actorUserId    String?       @map("actor_user_id") @db.Uuid
  organizationId String?       @map("organization_id") @db.Uuid
  actionType     String        @map("action_type")
  entityType     String        @map("entity_type")
  entityId       String        @map("entity_id")
  reasonCode     String?       @map("reason_code")
  reasonText     String?       @map("reason_text")
  oldValuesJson  Json?         @map("old_values_json")
  newValuesJson  Json?         @map("new_values_json")
  ipAddress      String?       @map("ip_address")
  deviceId       String?       @map("device_id")
  userAgent      String?       @map("user_agent")
  createdAt      DateTime      @default(now()) @map("created_at")
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  actorUser      User?         @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId])
  @@index([organizationId])
  @@index([entityType, entityId])
  @@index([actionType])
  @@map("audit_logs")
}

model ExportBatch {
  id                String             @id @default(uuid()) @db.Uuid
  profileCode       String             @map("profile_code")
  profileName       String?            @map("profile_name")
  filename          String
  organizationId    String?            @map("organization_id") @db.Uuid
  campaignId        String?            @map("campaign_id") @db.Uuid
  teamId            String?            @map("team_id") @db.Uuid
  regionCode        String?            @map("region_code")
  turfId            String?            @map("turf_id") @db.Uuid
  initiatedByUserId String?            @map("initiated_by_user_id") @db.Uuid
  markExported      Boolean            @default(false) @map("mark_exported")
  rowCount          Int                @default(0) @map("row_count")
  filterScopeJson   Json?              @map("filter_scope_json")
  csvContent        String?            @map("csv_content")
  sha256Checksum    String?            @map("sha256_checksum")
  purgeAt           DateTime?          @map("purge_at")
  createdAt         DateTime           @default(now()) @map("created_at")
  organization      Organization?      @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  campaign          Campaign?          @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  team              Team?              @relation(fields: [teamId], references: [id], onDelete: SetNull)
  turf              Turf?              @relation(fields: [turfId], references: [id], onDelete: SetNull)
  initiatedByUser   User?              @relation("ExportBatchesInitiated", fields: [initiatedByUserId], references: [id], onDelete: SetNull)
  exportedVisits    ExportBatchVisit[]

  @@index([profileCode])
  @@index([organizationId])
  @@index([campaignId])
  @@index([teamId])
  @@index([regionCode])
  @@index([turfId])
  @@index([initiatedByUserId])
