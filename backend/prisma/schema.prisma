model ImportBatch {
  id                    String           @id @default(uuid()) @db.Uuid
  profileCode           String           @default("van_standard") @map("profile_code")
  profileName           String?          @map("profile_name")
  filename              String
  organizationId        String?          @map("organization_id") @db.Uuid
  campaignId            String?          @map("campaign_id") @db.Uuid
  teamId                String?          @map("team_id") @db.Uuid
  regionCode            String?          @map("region_code")
  initiatedByUserId     String?          @map("initiated_by_user_id") @db.Uuid
  mode                  String
  duplicateStrategy     String           @map("duplicate_strategy")
  turfNameFallback      String?          @map("turf_name_fallback")
  rowCount              Int              @default(0) @map("row_count")
  importedCount         Int              @default(0) @map("imported_count")
  mergedCount           Int              @default(0) @map("merged_count")
  removedCount          Int              @default(0) @map("removed_count")
  pendingReviewCount    Int              @default(0) @map("pending_review_count")
  invalidCount          Int              @default(0) @map("invalid_count")
  duplicateSkippedCount Int              @default(0) @map("duplicate_skipped_count")
  mappingJson           Json?            @map("mapping_json")
  csvContent            String?          @map("csv_content")
  sha256Checksum        String?          @map("sha256_checksum")
  purgeAt               DateTime?        @map("purge_at")
  createdAt             DateTime         @default(now()) @map("created_at")
  organization          Organization?    @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  campaign              Campaign?        @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  team                  Team?            @relation(fields: [teamId], references: [id], onDelete: SetNull)
  initiatedByUser       User?            @relation("ImportBatchesInitiated", fields: [initiatedByUserId], references: [id], onDelete: SetNull)
  rows                  ImportBatchRow[]

  @@index([organizationId])
  @@index([campaignId])
  @@index([teamId])
  @@index([regionCode])
  @@index([initiatedByUserId])
  @@index([createdAt])
  @@map("import_batches")
}

model ImportBatchRow {
  id            String      @id @default(uuid()) @db.Uuid
  importBatchId String      @map("import_batch_id") @db.Uuid
  rowIndex      Int         @map("row_index")
  turfName      String?     @map("turf_name")
  status        String
  reasonCode    String?     @map("reason_code")
  rawRowJson    Json?       @map("raw_row_json")
  addressId     String?     @map("address_id") @db.Uuid
  candidateAddressId String? @map("candidate_address_id") @db.Uuid
  householdId   String?     @map("household_id") @db.Uuid
  resolvedByUserId String?  @map("resolved_by_user_id") @db.Uuid
  resolutionAction String?  @map("resolution_action")
  resolutionReason String?  @map("resolution_reason")
  resolvedAt     DateTime?  @map("resolved_at")
  createdAt     DateTime    @default(now()) @map("created_at")
  importBatch   ImportBatch @relation(fields: [importBatchId], references: [id], onDelete: Cascade)
  address       Address?    @relation("ResolvedImportBatchRowAddress", fields: [addressId], references: [id], onDelete: SetNull)
  candidateAddress Address? @relation("CandidateImportBatchRowAddress", fields: [candidateAddressId], references: [id], onDelete: SetNull)
  household     Household?  @relation(fields: [householdId], references: [id], onDelete: SetNull)
  resolvedByUser User?      @relation(fields: [resolvedByUserId], references: [id], onDelete: SetNull)

  @@index([importBatchId])
  @@index([addressId])
  @@index([candidateAddressId])
  @@index([householdId])
  @@index([resolvedByUserId])
  @@map("import_batch_rows")
}

model CsvProfile {
